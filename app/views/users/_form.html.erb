<div class="container">
  <%= render 'shared/errors', obj: @user %>
  <div class="row justify-content-center">
    <%= form_with(model: @user, class:"shadow p-3 mb-3 bg-warning rounded", local: true) do |f| %>
      <div class="row mb-3">
        <%= f.label :username, class: "col-2 col-form-label" %>
        <div class="col-10">
          <%= f.text_field :username, class: "form-control shadow rounded", placeholder: "Enter a username" %>
        </div>
      </div>

       <div class="row mb-3">
        <%= f.label :email, class: "col-2 col-form-label" %>
          <div class="col-10">
            <%= f.email_field :email, class: "form-control shadow rounded", placeholder: "Enter your email address" %>    
          </div>
      </div>

      <div class="row mb-3">
        <%= f.label :password, class: "col-2 col-form-label" %>
          <div class="col-10">
            <%= f.password_field :password, class: "form-control shadow rounded", placeholder: "Choose a password" %>    
          </div>
      </div>
     
      <div class="row mb-3 justify-content-center">
        <div class="col-auto"> <%= f.submit(@user.new_record? ? "Sign up" : "Update account", class: "btn btn-outline-light btn-lg") %>
        </div>
      </div>

    <% end %>

    <div class="text-center mt-2">
      <%= link_to '[ Cancel and return to articles listing ]', articles_path, class: "text-secondary" %>
    </div>
  </div>
</div>