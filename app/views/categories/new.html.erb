<h1 class="text-center mt-4">Create a new category</h1>

<div class="container">
  <%= render 'shared/errors', obj: @category %>
  <div class="row justify-content-center">
    <%= form_with(model: @category, class:"shadow p-3 mb-3 bg-warning rounded", local: true) do |f| %>
      <div class="row mb-3">
        <%= f.label :name, "Category name", class: "col-2 col-form-label" %>
        <div class="col-10">
          <%= f.text_field :name, class: "form-control shadow rounded", placeholder: "Enter a name" %>
        </div>
      </div>
     
      <div class="row mb-3 justify-content-center">
        <div class="col-auto"> <%= f.submit class: "btn btn-outline-light btn-lg" %>
        </div>
      </div>

    <% end %>

    <div class="text-center mt-2">
      <%= link_to '[ Cancel and return to articles listing ]', articles_path, class: "text-secondary" %>
    </div>
  </div>
</div>