<div class="container">
  <%= render 'shared/errors', obj: @article %>
  <div class="row justify-content-center">
    <%= form_with(model: @article, class:"shadow p-3 mb-3 bg-warning rounded", local: true) do |f| %>
      <div class="row mb-3">
        <%= f.label :title, class: "col-2 col-form-label" %>
        <div class="col-10">
          <%= f.text_field :title, class: "form-control shadow rounded", placeholder: "Title of article" %>
        </div>
      </div>

      <div class="row mb-3">
        <%= f.label :description, class: "col-2 col-form-label" %>
          <div class="col-10">
            <%= f.text_area :description, rows: 10, class: "form-control shadow rounded", placeholder: "Title of description" %>    
          </div>
      </div>

      <div class="row mb-3">
        <%= f.label :category, class: "col-2 col-form-label" %>
          <div class="col-10">
            <%= f.collection_select(:category_ids, Category.all, :id, :name,
              { prompt: "Make your select from the list below (can be empty)" }, 
              { multiple: true, size: 3, class: "form-select shadow rounded", style: "height: auto; min-height: 100px;" }) 
            %>
          </div>
      </div>

      <div class="row mb-3 justify-content-center">
        <div class="col-auto"> <%= f.submit class: "btn btn-outline-light btn-lg" %>
        </div>
      </div>

    <% end %>

    <div class="text-center mt-2">
      <%= link_to '[ Cancel and return to articles listing ]', articles_path, class: "text-secondary" %>
    </div>
  </div>
</div>